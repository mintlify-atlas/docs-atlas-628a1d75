  "keyFeatures": [
    "Real-time and batch data ingestion from Kafka, Kinesis, and files",
    "SQL and native query interfaces for analytics",
    "Distributed architecture with specialized services (Coordinator, Broker, Historical, Overlord)",
    "Column-oriented storage with segment-based data organization",
    "Multi-stage query engine for complex analytics",
    "Built-in web console for data management and monitoring",
    "Automatic compaction and retention management",
    "Support for streaming and batch workloads"
  ],
  "publicApiSurface": [
    "SQL Query API (HTTP and JDBC)",
    "Native JSON Query API",
    "SQL Ingestion API",
    "Tasks API (data ingestion management)",
    "Supervisor API (streaming ingestion lifecycle)",
    "Data Management API (segment operations)",
    "Lookups API (key-value datasources)",
    "Retention Rules API",
    "Automatic Compaction API",
    "Service Status API",
    "Dynamic Configuration API"
  ]
